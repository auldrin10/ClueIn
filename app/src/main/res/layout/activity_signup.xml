<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/main" android:gravity="center" android:layout_width="match_parent" android:layout_height="match_parent" tools:context=".MainActivity">

    <!--    Sign up textView and User Account Icon-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="0dp"
        android:layout_marginBottom="780dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf= "parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.501"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.102">
        <!--Sign Up textView-->
        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Sign Up"
            android:textColor="@color/navy"
            android:textSize="25dp"
            android:textStyle="bold" />

        <!--User Account Circle Icon-->
        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="84dp"
            android:layout_height="98dp"
            app:srcCompat="@drawable/outline_account_circle_24" />
    </LinearLayout>


    <!-- Linear layout for the text inputs and checkbox -->
    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="370dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.508"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.291"
        android:gravity="center">
        <!--   Full Name TextInput -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtInptUser"
                android:layout_width="367dp"
                android:inputType="text"
                android:layout_height="56dp"
                android:background="@drawable/rounded_corner_username"
                android:hint="Full Name"
                android:paddingLeft="25dp"
                android:drawableEnd="@drawable/baseline_account_circle_24"
                android:paddingEnd="10dp"
                android:textColorHint="#ff625b71"
                android:textSize="18dp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!--   Email TextInput -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center">
            <com.google.android.material.textfield.TextInputEditText

                android:id="@+id/txtInptEmail"
                android:layout_width="367dp"
                android:layout_height="56dp"
                android:background="@drawable/rounded_corner_username"
                android:drawableEnd="@drawable/baseline_email_24"
                android:paddingEnd="10dp"
                android:hint="Email Address"
                android:inputType="textEmailAddress"
                android:paddingLeft="25dp"
                android:textColorHint="#ff625b71"
                android:textSize="18dp"/>
        </com.google.android.material.textfield.TextInputLayout>
        <!--   Password TextInput -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:helperTextEnabled="true"
            app:counterEnabled="true"

            app:passwordToggleEnabled="true"
            app:passwordToggleTint="@color/black"
            app:boxStrokeColor="@color/black"
            android:gravity="center">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtInptPassword"
                android:layout_width="367dp"
                android:layout_height="56dp"

                android:background="@drawable/rounded_corner_username"
                android:hint="Password"
                android:paddingLeft="25dp"
                android:textColorHint="#ff625b71"
                android:textSize="19.99dp"/>
            <!--Password validation checklist-->
            <CheckBox
                android:id="@+id/chckBoxEightChars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"
                android:layout_weight="1"
                android:layout_marginLeft="-107.7dp"
                android:text="Atleast 8 characters"
                />

            <CheckBox
                android:id="@+id/chckBoxNumbers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="-104dp"
                android:text="Should have numbers" />
            <CheckBox
                android:id="@+id/chckBoxLowerCaseChar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="-85.6dp"
                android:text="Minimum of one lowercase"/>

            <CheckBox
                android:id="@+id/chckBoxUpperCaseChar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="-85dp"
                android:text="Minimum of one uppercase" />

            <CheckBox
                android:id="@+id/chckBoxSpecialChar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="-64.6dp"
                android:text="Minimum of one special character" />

        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="200dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.508"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.291"
        >
        <!-- CheckBox where user agrees with our terms and conditions -->

        <CheckBox android:id="@+id/checkBox"
            android:layout_width="371dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:text="I agree to the Terms of Service and Privacy Policy"
            android:textSize="15.2dp"/>

        <!--     Sign Up Button -->
        <Button
            android:id="@+id/btnSignUp"
            android:layout_width="372dp"
            android:layout_height="62dp"
            android:layout_marginTop="50dp"
            android:background="@drawable/sign_up_button"
            android:text="Sign Up"
            android:textColor="@color/navy"
            android:textSize="24dp"
            android:textStyle="bold" />

    </LinearLayout>


    <!--Linear Layout for the or line-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="150dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.834">
        <View
            android:layout_width="70dp"
            android:layout_height="1.7dp"
            android:layout_weight="1"
            android:background="#FF5678"/>

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="OR"
            android:textColor="@color/navy"
            android:textSize="17dp"
            android:textStyle="bold" />
        <View
            android:layout_width="70dp"
            android:layout_height="1.7dp"
            android:layout_weight="1"
            android:background="#FF5678"/>
    </LinearLayout>

    <!--Linear layout for the social media icons-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="62dp"
        android:gravity="center"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="635dp">
        <ImageView android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="20dp"
            android:src="@drawable/google"
            tools:layout_editor_absoluteX="31dp"
            tools:layout_editor_absoluteY="647dp"/>
        <ImageView android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="20dp"
            android:src="@drawable/instagram"
            tools:layout_editor_absoluteX="333dp"
            tools:layout_editor_absoluteY="569dp"/>
        <ImageView android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="20dp"
            android:src="@drawable/facebook"
            tools:layout_editor_absoluteX="333dp"
            tools:layout_editor_absoluteY="647dp"/>
    </LinearLayout>

    <!--Login related question-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="44dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.105"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.771"
        android:gravity="center">

        <TextView android:id="@+id/textView2"
            android:layout_width="231dp"
            android:layout_height="wrap_content"
            android:text="Already have an account?"
            android:textSize="17dp"/>
        <TextView android:id="@+id/txtViewLogIn"
            android:layout_width="59dp"
            android:layout_height="wrap_content"
            android:text="LogIn" android:textSize="17dp"
            android:layout_marginLeft="1dp"/>
    </LinearLayout>

    <!--Progress indicator -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/indicator"
        android:layout_width="match_parent"
        android:layout_height="89dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp">

    </androidx.viewpager2.widget.ViewPager2>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"

        android:orientation="horizontal"
        android:gravity="center"
        >
        <androidx.cardview.widget.CardView
            android:layout_width="15dp"
            android:layout_height="15dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="30dp"

            >
            <ImageView
                android:id="@+id/indic1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@color/orange"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="15dp"
            android:layout_height="15dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="30dp"
            android:layout_marginLeft="16dp"
            >
            <ImageView
                android:id="@+id/indic2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@color/orange"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</RelativeLayout>