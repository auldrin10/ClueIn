<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp"
        tools:context=".SignUpActivity">

        <!-- Sign up Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up"
                android:textColor="@color/navy"
                android:textSize="25sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="84dp"
                android:layout_height="98dp"
                app:srcCompat="@drawable/outline_account_circle_24" />
        </LinearLayout>

        <!-- Input Fields Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/nameLayout"
                android:layout_width="355dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/MyTextInputLayout"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="30dp"
                app:boxCornerRadiusBottomStart="30dp"
                app:boxCornerRadiusTopEnd="30dp"
                app:boxCornerRadiusTopStart="30dp"
                app:boxStrokeWidth="2dp"
                app:boxStrokeColor="@color/input_stroke"
                app:hintTextColor="@color/orange"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtInptUser"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:drawableEnd="@drawable/baseline_account_circle_24"
                    android:hint="Full Name"
                    android:inputType="text"
                    android:paddingStart="25dp"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailLayout"
                android:layout_width="355dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/MyTextInputLayout"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="30dp"
                app:boxCornerRadiusBottomStart="30dp"
                app:boxCornerRadiusTopEnd="30dp"
                app:boxCornerRadiusTopStart="30dp"
                app:boxStrokeWidth="2dp"
                app:boxStrokeColor="@color/input_stroke"
                app:hintTextColor="@color/orange">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtInptEmail"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:drawableEnd="@drawable/baseline_email_24"
                    android:hint="Email Address"
                    android:inputType="textEmailAddress"
                    android:paddingStart="25dp"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passwordLayout"
                style="@style/MyTextInputLayout"
                android:layout_width="355dp"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="30dp"
                app:boxCornerRadiusBottomStart="30dp"
                app:boxCornerRadiusTopEnd="30dp"
                app:boxCornerRadiusTopStart="30dp"
                app:boxStrokeColor="@color/input_stroke"
                app:boxStrokeWidth="2dp"
                app:hintTextColor="@color/orange"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/orange">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txtInptPassword"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Password"
                    android:paddingStart="25dp"
                    android:inputType="textPassword"
                    android:textColor="@color/black"
                    android:textCursorDrawable="@null"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Validations Section -->
        <LinearLayout
            android:id="@+id/validationLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <!-- Number Validation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:id="@+id/iconLength"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/multiplication" />
                <TextView
                    android:id="@+id/chckBoxEightChars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:text="Atleast 8 characters "
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- 8 Characters Validation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:id="@+id/iconAtLeastNum"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/multiplication" />
                <TextView
                    android:id="@+id/chckBoxNumbers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:text="Should have numbers"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Lowercase Validation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:id="@+id/iconLower"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/multiplication" />
                <TextView
                    android:id="@+id/chckBoxLowerCaseChar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:text="Minimum of one lowercase"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Uppercase Validation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:id="@+id/iconUpper"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/multiplication" />
                <TextView
                    android:id="@+id/chckBoxUpperCaseChar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:text="Minimum of one uppercase"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Special Char Validation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <ImageView
                    android:id="@+id/iconSpecialChar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/multiplication" />
                <TextView
                    android:id="@+id/chckBoxSpecialChar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="15dp"
                    android:text="Minimum of one special character"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Signup and Terms Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/checkBox"
                android:layout_width="355dp"
                android:layout_height="wrap_content"
                android:text="I agree to the Terms of Service and Privacy Policy"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="355dp"
                android:layout_height="61dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/sign_up_button"
                android:text="Sign Up"
                android:textAllCaps="false"
                android:textColor="@color/navy"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- "OR" Divider Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:orientation="horizontal">
            <View
                android:layout_width="0dp"
                android:layout_height="1.7dp"
                android:layout_weight="1"
                android:background="#FF5678" />
            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="OR"
                android:textColor="@color/navy"
                android:textSize="17sp"
                android:textStyle="bold" />
            <View
                android:layout_width="0dp"
                android:layout_height="1.7dp"
                android:layout_weight="1"
                android:background="#FF5678" />
        </LinearLayout>

        <!-- Social Media Icons Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="15dp"
                android:src="@drawable/google" />
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="15dp"
                android:src="@drawable/instagram" />
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="15dp"
                android:src="@drawable/facebook" />
        </LinearLayout>

        <!-- Footer / Login Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/txtViewLogIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="ToLogIn"
                android:text="LogIn"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/orange"/>
        </LinearLayout>

        <!-- Progress Indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:id="@+id/dot1"
                android:layout_width="13dp"
                android:layout_height="12dp"
                android:layout_margin="6dp"
                android:background="@drawable/dot_inactive" />
            <View
                android:id="@+id/dot2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_margin="6dp"
                android:background="@drawable/dot_inactive" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>