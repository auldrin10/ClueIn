<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ClueIn" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <item name="colorPrimary">@color/orange</item>
        <item name="colorPrimaryVariant">@color/orange</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
    </style>

    <style name="DialogTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <item name="colorAccent">@color/orange</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorAccent">@color/orange</item>
        <item name="android:windowBackground">@drawable/custom_dialog_bg</item>
    </style>

    <style name="Theme.ClueIn" parent="Base.Theme.ClueIn" />
</resources>